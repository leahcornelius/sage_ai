OPENAI_API_KEY=your-openai-api-key
SAGE_API_KEY=your-sage-api-key
# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# SAGE_HOST=0.0.0.0
# SAGE_PORT=8787
# SAGE_LOG_LEVEL=info
# SAGE_LOG_CONSOLE_LEVEL=info
# SAGE_LOG_FILE_LEVEL=debug
# SAGE_LOG_FILE_PATH=logs/sage.log
# SAGE_LOG_FILE_ENABLED=true
# SAGE_LOG_PRETTY=true
# SAGE_CORS_ORIGIN=http://localhost:3000
# SAGE_OPENAI_MODEL_ALLOWLIST=gpt-4.1-mini,gpt-5.2
# SAGE_MODEL_CACHE_TTL_MS=60000
# SAGE_MEMORY_TOP_K=5
# SAGE_MEMORY_EXTRACTION_MODEL=gpt-4.1-mini
# SAGE_TOOLS_ENABLED=true
# SAGE_TOOL_MAX_ROUNDS=6
# SAGE_TOOL_TIMEOUT_MS=10000
# SAGE_TOOL_MAX_PARALLEL_CALLS=4
# SAGE_MEMORY_TOOL_WRITE_ENABLED=true
# SAGE_MCP_SERVERS_JSON=[{"name":"web","transport":"http","url":"https://mcp.example.com","required":false},{"name":"brave","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-brave-search"],"env":{"BRAVE_API_KEY":"your-key"},"required":false}]
# WEB_SEARCH_ENABLED=true
# BRAVE_API_KEY=your-brave-api-key
# SAGE_BRAVE_MODE=llm_context
# SAGE_BRAVE_MAX_RESULTS=5
# SAGE_BRAVE_TIMEOUT_MS=8000
# SAGE_BRAVE_SAFESEARCH=off
# SAGE_BRAVE_COUNTRY=GB
# SAGE_BRAVE_SEARCH_LANG=en
# SAGE_DOC_CACHE_TTL_MS=3600000
# SAGE_DOC_CACHE_MAX_DOCS=500
# SAGE_DOC_CACHE_MAX_DOC_BYTES=4194304
# SAGE_SYSTEM_PROMPT_PATH=./system_prompt.yaml
# MNEMOSYNE_VECTOR_DB_URL=http://localhost:6333
# MNEMOSYNE_EMBEDDING_URL=http://localhost:11434/v1/embeddings
# MNEMOSYNE_GRAPH_DB_URL=redis://localhost:6380
# MNEMOSYNE_CACHE_URL=redis://localhost:6379
# MNEMOSYNE_AGENT_ID=sage-api
# MNEMOSYNE_EMBEDDING_MODEL=nomic-embed-text
